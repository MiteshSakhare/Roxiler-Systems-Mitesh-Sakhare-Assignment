# Ignore everything in the root except specific files if needed
# but mostly we'll ignore node_modules and env files globally.
node_modules/
.env
.DS_Store
.idea/
.vscode/

# Ignore frontend build outputs
frontend/dist/
frontend/dist-ssr/

# Ignore backend build outputs
backend/dist/
backend/build/
backend/out/

# Ignore npm logs globally
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
